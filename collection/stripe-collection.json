    {
      "name": "CreatePaymentIntent",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "let jsonData = pm.response.json();",
              "",
              "// 1. Status Code",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 2. Headers Authorization",
              "pm.test(\"Response has Content-Type: application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Request was authenticated (not 401 or 403)\", function () {",
              "    pm.expect(pm.response.code).to.not.equal(401);",
              "    pm.expect(pm.response.code).to.not.equal(403);",
              "});",
              "pm.environment.set(\"chargeId\", jsonData.latest_charge);",
              "",
              "// 3. Schema Validation",
              "pm.test(\"Response matches Payment Intent JSON schema\", function () {",
              "    const schema = {",
              "        type: \"object\",",
              "        required: [",
              "            \"id\", \"object\", \"amount\", \"amount_capturable\", \"amount_received\",",
              "            \"capture_method\", \"client_secret\", \"confirmation_method\", \"created\",",
              "            \"currency\", \"customer\", \"latest_charge\", \"livemode\", \"metadata\",",
              "            \"payment_method\", \"payment_method_options\", \"payment_method_types\", \"status\"",
              "        ],",
              "        properties: {",
              "            id: { type: \"string\" },",
              "            object: { type: \"string\" },",
              "            amount: { type: \"number\" },",
              "            amount_capturable: { type: \"number\" },",
              "            amount_received: { type: \"number\" },",
              "            capture_method: { type: \"string\" },",
              "            client_secret: { type: \"string\" },",
              "            confirmation_method: { type: \"string\" },",
              "            created: { type: \"number\" },",
              "            currency: { type: \"string\" },",
              "            customer: { type: \"string\" },",
              "            latest_charge: { type: \"string\" },",
              "            livemode: { type: \"boolean\" },",
              "            metadata: { type: \"object\" },",
              "            payment_method: { type: \"string\" },",
              "            payment_method_types: { type: \"array\", items: { type: \"string\" } },",
              "            status: { type: \"string\" },",
              "            payment_method_options: {",
              "                type: \"object\",",
              "                properties: {",
              "                    us_bank_account: {",
              "                        type: \"object\",",
              "                        required: [\"verification_method\", \"transaction_purpose\"],",
              "                        properties: {",
              "                            verification_method: { type: \"string\" },",
              "                            transaction_purpose: { type: \"string\" }",
              "                        }",
              "                    }",
              "                }",
              "            }",
              "        }",
              "    };",
              "    pm.expect(jsonData).to.have.jsonSchema(schema);",
              "});",
              "",
              "// 4. Essential Property Validations",
              "",
              "pm.test(\"id exists and starts with 'pi_'\", function () {",
              "    pm.expect(jsonData.id).to.be.a(\"string\");",
              "    pm.expect(jsonData.id).to.match(/^pi_/);",
              "});",
              "",
              "pm.test(\"object equals 'payment_intent'\", function () {",
              "    pm.expect(jsonData.object).to.equal(\"payment_intent\");",
              "});",
              "",
              "pm.test(\"amount is a number and equals 2000\", function () {",
              "    pm.expect(jsonData.amount).to.be.a(\"number\");",
              "    pm.expect(jsonData.amount).to.equal(2000);",
              "});",
              "",
              "pm.test(\"currency equals 'usd'\", function () {",
              "    pm.expect(jsonData.currency).to.equal(\"usd\");",
              "});",
              "",
              "pm.test(\"status exists and is a valid Payment Intent status\", function () {",
              "    const validStatuses = [",
              "        \"requires_payment_method\",",
              "        \"requires_confirmation\",",
              "        \"requires_action\",",
              "        \"processing\",",
              "        \"requires_capture\",",
              "        \"canceled\",",
              "        \"succeeded\"",
              "    ];",
              "    pm.expect(jsonData.status).to.be.a(\"string\");",
              "    pm.expect(validStatuses).to.include(jsonData.status);",
              "});",
              "",
              "pm.test(\"client_secret exists and is a non-empty string\", function () {",
              "    pm.expect(jsonData.client_secret).to.be.a(\"string\").and.to.have.length.above(0);",
              "});",
              "",
              "pm.test(\"payment_method_types is an array and contains 'us_bank_account'\", function () {",
              "    pm.expect(jsonData.payment_method_types).to.be.an(\"array\");",
              "    pm.expect(jsonData.payment_method_types).to.include(\"us_bank_account\");",
              "});",
              "",
              "pm.test(\"customer exists and starts with 'cus_'\", function () {",
              "    pm.expect(jsonData.customer).to.be.a(\"string\");",
              "    pm.expect(jsonData.customer).to.match(/^cus_/);",
              "});",
              "",
              "pm.test(\"payment_method exists and starts with 'pm_'\", function () {",
              "    pm.expect(jsonData.payment_method).to.be.a(\"string\");",
              "    pm.expect(jsonData.payment_method).to.match(/^pm_/);",
              "});",
              "",
              "pm.test(\"livemode is a boolean (false for test mode)\", function () {",
              "    pm.expect(jsonData.livemode).to.be.a(\"boolean\");",
              "    pm.expect(jsonData.livemode).to.equal(false);",
              "});",
              "",
              "pm.test(\"latest_charge exists\", function () {",
              "    pm.expect(jsonData.latest_charge).to.exist;",
              "});",
              "",
              "pm.test(\"capture_method equals 'automatic_async'\", function () {",
              "    pm.expect(jsonData.capture_method).to.equal(\"automatic_async\");",
              "});",
              "",
              "pm.test(\"confirmation_method equals 'automatic'\", function () {",
              "    pm.expect(jsonData.confirmation_method).to.equal(\"automatic\");",
              "});",
              "",
              "pm.test(\"created is a number (Unix timestamp)\", function () {",
              "    pm.expect(jsonData.created).to.be.a(\"number\");",
              "    pm.expect(jsonData.created).to.be.above(0);",
              "});",
              "",
              "pm.test(\"payment_method_options.us_bank_account exists with verification_method and transaction_purpose\", function () {",
              "    const usBankAccount = jsonData.payment_method_options && jsonData.payment_method_options.us_bank_account;",
              "    pm.expect(usBankAccount).to.be.an(\"object\");",
              "    pm.expect(usBankAccount).to.have.property(\"verification_method\");",
              "    pm.expect(usBankAccount).to.have.property(\"transaction_purpose\");",
              "});",
              "",
              "pm.test(\"amount_received is a number\", function () {",
              "    pm.expect(jsonData.amount_received).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"amount_capturable is a number\", function () {",
              "    pm.expect(jsonData.amount_capturable).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"metadata is an object\", function () {",
              "    pm.expect(jsonData.metadata).to.be.an(\"object\");",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
